{
  "extends": ["github>open-turo/renovate-config#v1.17.1"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["action\\.yaml$"],
      "matchStrings": [
        "# Default Node version is v(?<currentValue>\\d+)",
        "echo \"version=(?<currentValue>\\d+)\" >> \\$GITHUB_OUTPUT"
      ],
      "depNameTemplate": "node",
      "datasourceTemplate": "node-version"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["action\\.yaml$"],
      "matchStrings": ["\"(?<depName>@[^\"]+?)@(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "npm"
    }
  ]
}
